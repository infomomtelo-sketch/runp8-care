# =====================================================================
# Title22 (title22.app) — configuration reference
# =====================================================================
# The frontend is a static single-file SPA (index.html) deployed on
# Cloudflare Pages. It has NO build step, so nothing here is injected at
# build time — the public values below are hardcoded constants near the
# top of the <script> block in index.html. This file documents every
# value the system depends on and where it lives.

# ---- Public values hardcoded in index.html (safe to expose) ----
SUPABASE_URL=https://nwlhsshvqmbhemhxcran.supabase.co
SUPABASE_ANON_KEY=<anon key — public, RLS enforces access>
AI_WORKER_URL=https://title22-ai.infomomtelo.workers.dev/api/chat
STRIPE_PAYMENT_LINK_STARTER=https://buy.stripe.com/00w6oGdmy28K2bpes6g360f
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/8x2cN40zM7t49DR3Nsg360g
STRIPE_PAYMENT_LINK_SPECIALIST=https://buy.stripe.com/28E14m1DQ28Kg2f4Rwg360h
STRIPE_PAYMENT_LINK_AGENCY=https://buy.stripe.com/7sYbJ00zMbJkeYb97Mg360i
STRIPE_CUSTOMER_PORTAL=https://billing.stripe.com/p/login/3cIfZgbeq6p03ft1Fkg3600

# ---- Cloudflare Worker: title22-ai (secrets via `wrangler secret put`) ----
# Server-side only. NEVER ship these to the client.
ANTHROPIC_API_KEY=<anthropic api key>
# Needed to verify the caller's Supabase JWT and read/write ai_usage:
SUPABASE_SERVICE_ROLE_KEY=<service role key — server only>

# ---- Cloudflare Worker: stripe-webhook (secrets via `wrangler secret put`) ----
STRIPE_SECRET_KEY=<sk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_... for destination "memorable-wonder">
# stripe-webhook also needs SUPABASE_SERVICE_ROLE_KEY (above) to write
# title22_plan / title22_subscription_id / title22_plan_expires_at.

# ---- Transactional email (Resend) ----
RESEND_API_KEY=<re_...>
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
EMAIL_FROM=noreply@send.thejudgy.com
